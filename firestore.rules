rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS COLLECTION ─────────────────────────────────────────────────
    // A logged-in user can read and write only their OWN document.
    // The Admin SDK (used by the backend on Render) bypasses these rules entirely.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── COMPANY DETAILS COLLECTION ────────────────────────────────────────
    match /companyDetails/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── NFC CARDS ─────────────────────────────────────────────────────────
    // Users can read/write cards assigned to them.
    match /nfcCards/{cardId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── TEMPLATES (admin-managed, read-only for users) ────────────────────
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false; // Only Admin SDK (backend) can write
    }

    // ── CATEGORIES ────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if false;
    }

    // ── INQUIRIES ─────────────────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
