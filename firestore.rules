rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS COLLECTION ─────────────────────────────────────────────────
    // Individual identity nodes are publicly readable for sharing.
    // Master registry list is restricted to the Administrator.
    match /users/{userId} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.token.email == 'admin@gmail.com';
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── COMPANY DETAILS COLLECTION ────────────────────────────────────────
    match /companyDetails/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'admin@gmail.com');
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── NFC CARDS ─────────────────────────────────────────────────────────
    // Users can read/write cards assigned to them.
    match /nfcCards/{cardId} {
      allow read, write: if request.auth != null;
    }

    // ── TEMPLATES (admin-managed, read-only for users) ────────────────────
    match /templates/{templateId} {
      allow read: if true;
      allow write, delete: if request.auth != null && request.auth.token.email == 'admin@gmail.com';
    }

    // ── CATEGORIES ────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write, delete: if request.auth != null && request.auth.token.email == 'admin@gmail.com';
    }

    // ── INQUIRIES ─────────────────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      allow get: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.email == 'admin@gmail.com');
      allow list: if request.auth != null && request.auth.token.email == 'admin@gmail.com';
      allow create: if true;
      allow update, delete: if request.auth != null && request.auth.token.email == 'admin@gmail.com';
    }
  }
}
